        h2 { font-size: 14pt; font-weight: bold; margin-top: 30px; margin-bottom: 10px; }
        h3 { font-size: 12pt; font-weight: bold; margin-top: 15px; }
        table { border-collapse: collapse; width: 100%; margin-bottom: 15px; font-size: 11pt; }
