    <title>Latar Belakang - SIFAKTUR</title>
    <style>
        @page { size: A4; margin: 2cm 2.5cm 2cm 3cm; }
        body { font-family: "Times New Roman", Times, serif; font-size: 12pt; line-height: 1.8; }
        h1 { font-size: 14pt; font-weight: bold; margin-top: 25px; margin-bottom: 10px; }
        p { text-align: justify; margin-bottom: 10px; text-indent: 40px; }
